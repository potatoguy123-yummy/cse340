<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">
    <div class="form-group">
      <label for="title">Project Title</label>
      <input
        type="text"
        id="title"
        name="title"
        maxlength="150"
        value="<%= projectDetails.title %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        maxlength="500"
        required
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        maxlength="255"
        value="<%= projectDetails.location %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input
        type="date"
        id="date"
        name="date"
        value="<%= new Date(projectDetails.date).toISOString().split('T')[0] %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select
        id="organizationId"
        name="organizationId"
        required
      >
        <option value="">Select an organization</option>
        <% organizations.forEach(org => { %>
          <option value="<%= org.organization_id %>"
            <%= org.organization_id === projectDetails.organization_id ? 'selected' : '' %>>
            <%= org.name %>
          </option>
        <% }); %>
      </select>
    </div>

    <button type="submit">Edit Project</button>

</main>
<%- include('partials/footer') %>
