<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Dashboard</h2>
    <p>Name: <%= name %></p>
    <p>Username: <%= email %></p>

    <h3>Your Volunteer Projects</h3>
    <% if (volunteerProjects.length > 0) { %>
        <ul>
            <% volunteerProjects.forEach(function(project) { %>
                <li>
                    <strong><a href="/project/<%= project.project_id %>"><%= project.title %></a></strong> - <%= project.organization_name %>
                    <a href="/volunteer/<%= project.project_id %>/remove">Remove Volunteer</a>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>You have not volunteered for any projects yet.</p>
    <% } %>

    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/users">View All Users</a></p>
    <% } %>
</main>
<%- include('partials/footer') %>
