<%- include('partials/header') %>
<main>
    <article>
        <h1><%= details.title %></h1>
        
        <div class="project-details">
            <p class="description"><%= details.description %></p>
            
            <div class="details-grid">
                <div class="detail-item">
                    <strong>Project ID:</strong> <%= details.project_id %>
                </div>
                
                <div class="detail-item">
                    <strong>Location:</strong> <%= details.location %>
                </div>
                
                <div class="detail-item">
                    <strong>Category:</strong> <a href="/category/<%= details.project_category %>"><%= details.category_name %></a>
                </div>
                
                <div class="detail-item">
                    <strong>Date:</strong> <%= new Date(details.date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                        weekday: 'long'
                    }) %>
                </div>
                
                <div class="detail-item">
                    <strong>Organization:</strong> 
                    <a href="/organization/<%= details.organization_id %>">
                        <%= details.organization_name %>
                    </a>
                </div>
            </div>
        </div>
        
        <div class="navigation-links">
            <a href="/projects" class="btn">&larr; Back to Projects</a>
            <% if (isLoggedIn) { %>
                <% if (hasVolunteered) { %>
                    <a href="/volunteer/<%= details.project_id %>/remove" class="btn">Un-Volunteer from this project</a>
                <% } else { %>
                    <a href="/volunteer/<%= details.project_id %>" class="btn">Volunteer for This Project</a>
                <% } %>
            <% } %>
            <% if (user && user.role_name === 'admin') { %>
            <a href="/assign-categories/<%= details.project_id %>">Edit Categories</a>
            <a href="/edit-project/<%= details.project_id %>">Edit Project</a>
            <% } %>
        </div>
    </article>
</main>
<%- include('partials/footer') %>